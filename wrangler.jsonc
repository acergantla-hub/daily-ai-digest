{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "daily-ai-digest",
  "compatibility_date": "2026-05-30",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "pages_build_output_dir": "dist"
}
